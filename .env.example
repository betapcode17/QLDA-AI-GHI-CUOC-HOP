# =====================================================================
# QLDA-AI-GHI-CUOC-HOP Environment Configuration
# =====================================================================
# Copy this file to .env and adjust values as needed

# =====================================================================
# OLLAMA LLM Configuration
# =====================================================================
# Ollama API endpoint (must be running)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Ollama model to use for LLM tasks (must be pulled beforehand)
# Supported: qwen2.5:3b, llama2:7b, neural-chat, mistral, etc.
OLLAMA_MODEL=qwen2.5:3b

# Timeout for Ollama API requests (seconds)
OLLAMA_TIMEOUT_SECONDS=120

# =====================================================================
# Model Paths Configuration
# =====================================================================
# Leave empty or undefined to use default project-relative paths
# Set these to use custom model locations (e.g., /mnt/models, C:\Models)

# STT Model (Speech-to-Text) - PhoWhisper
# Default: ./models/stt/PhoWhisper-medium-ct2-int8
STT_MODEL_DIR=

# Diarization Model (Speaker identification)
# Default: ./models/diarization/speaker-diarization-community-1
DIARIZATION_MODEL_DIR=

# Translation Models (Vietnamese <-> English)
# Defaults: ./models/translation/opus-mt-vi-en and opus-mt-en-vi
TRANSLATION_VI_EN_DIR=
TRANSLATION_EN_VI_DIR=

# Summarization Model (BART)
# Default: ./models/summarization/bart-large-cnn
SUMMARIZATION_MODEL_DIR=

# =====================================================================
# Transformers & HuggingFace Hub Settings
# =====================================================================
# Disable TorchCodec warning (recommended for CPU)
TRANSFORMERS_NO_TORCHCODEC=1

# Disable symlinks warning
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Disable tokenizers parallelism warning
TOKENIZERS_PARALLELISM=false

# =====================================================================
# Application Settings
# =====================================================================
# Default language for transcription (vi for Vietnamese, en for English)
# Default: vi
DEFAULT_LANGUAGE=vi

# STT compute type (int8 for CPU optimization, default is int8)
# Options: int8, float16, float32
STT_COMPUTE_TYPE=int8

# STT CPU threads
STT_CPU_THREADS=4

# =====================================================================
# Audio Processing Settings
# =====================================================================
# Audio sample rate for processing
AUDIO_SAMPLE_RATE=16000

# Minimum duration (seconds) for VAD (Voice Activity Detection) to activate
STT_VAD_MIN_DURATION_SECONDS=8.0

# Minimum duration (seconds) for diarization to be attempted
MIN_DIARIZATION_DURATION_SECONDS=8.0

# =====================================================================
# Low VRAM GPU Settings (recommended for 4GB GPUs)
# =====================================================================
# Keep this enabled when STT and diarization cannot fit in VRAM together.
AI_LOW_VRAM_MODE=1
PRELOAD_MODELS=0

# Run both tasks on GPU, but only one model is kept in VRAM at a time.
MODEL_DEVICE=cuda
STT_DEVICE=cuda
DIARIZATION_DEVICE=cuda

# Smaller STT chunks and token budget reduce temporary generation memory.
STT_CHUNK_DURATION=15
STT_MAX_NEW_TOKENS=256
STT_MIN_SEGMENT_SECONDS=1.0

# Diarization uses GPU unless free VRAM is extremely low.
DIARIZATION_GPU_MEMORY_LIMIT_MB=900
DIARIZATION_GPU_CUTOFF_RATIO=0.20
DIARIZATION_GPU_CUTOFF_FLOOR_MB=700
DIARIZATION_MERGE_GAP_SECONDS=0.35
SKIP_DIARIZATION_WHEN_SINGLE_SPEAKER=1
